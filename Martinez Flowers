<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Martinez’s Flower Designs 💙</title>

<link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Pacifico', cursive;
  background: linear-gradient(#d9ecff, #b3d1ff);
  color: #1f2a44;
  overflow-x: hidden;
  opacity: 0;
  animation: fadeIn 1.5s forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

/* 🎀 WELCOME SCREEN */
#welcome {
  position: fixed;
  width: 100%;
  height: 100%;
  background: linear-gradient(#b3d1ff, #d9ecff);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  animation: fadeOut 2s ease 3s forwards;
}

@keyframes fadeOut {
  to { opacity: 0; visibility: hidden; }
}

#welcome h1 {
  color: #2f5fbf;
  font-size: 30px;
}

/* 🎵 MUSIC BUTTON */
#musicBtn {
  position: fixed;
  bottom: 15px;
  right: 15px;
  background: #2f5fbf;
  color: white;
  padding: 10px;
  border-radius: 10px;
  cursor: pointer;
  z-index: 999;
}

/* HEADER */
header {
  background: #4d8dff;
  text-align: center;
  padding: 25px;
  font-size: 28px;
  color: white;
}

/* 🐱 HELLO KITTY */
.kitty {
  position: fixed;
  width: 70px;
  animation: kittyFloat 4s infinite ease-in-out;
  z-index: 1;
}

.k1 { left: 10px; top: 120px; }
.k2 { left: 15px; top: 350px; animation-delay: 1s; }
.k3 { right: 10px; top: 180px; animation-delay: 0.5s; }
.k4 { right: 15px; top: 420px; animation-delay: 1.5s; }

@keyframes kittyFloat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-25px); }
  100% { transform: translateY(0); }
}

/* 💙 HEARTS */
.heart {
  position: fixed;
  color: #4da6ff;
  font-size: 18px;
  animation: floatUp linear infinite;
  z-index: 0;
}

@keyframes floatUp {
  0% { transform: translateY(100vh); opacity: 0; }
  10% { opacity: 1; }
  100% { transform: translateY(-10vh); opacity: 0; }
}

section {
  padding: 25px 15px;
  text-align: center;
  position: relative;
  z-index: 2;
}

.card {
  background: white;
  margin: 15px auto;
  padding: 15px;
  max-width: 380px;
  border-radius: 20px;
  box-shadow: 0 5px 10px rgba(0,0,0,0.1);
}

button {
  background: #2f5fbf;
  border: none;
  color: white;
  padding: 12px 18px;
  border-radius: 15px;
  font-size: 16px;
  cursor: pointer;
  margin: 5px;
}

textarea, input {
  width: 85%;
  padding: 10px;
  margin: 6px;
  border-radius: 10px;
  border: 1px solid #ccc;
}

/* 💌 THANK YOU POPUP */
#thankyou {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  padding: 25px;
  border-radius: 20px;
  display: none;
  z-index: 9999;
  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  text-align: center;
}
</style>
</head>

<body>

<!-- 🎀 WELCOME -->
<div id="welcome">
  <h1>💙 Welcome to Martinez’s Flower Designs 💙</h1>
  <p>Loading your flower shop...</p>
</div>

<!-- 🎵 MUSIC -->
<audio id="music" loop>
  <source src="https://cdn.pixabay.com/download/audio/2022/10/25/audio_2c7b3a5a4a.mp3?filename=soft-piano-ambient-112191.mp3" type="audio/mp3">
</audio>

<div id="musicBtn" onclick="toggleMusic()">🎵 Music</div>

<!-- 🐱 HELLO KITTY -->
<img class="kitty k1" src="https://i.imgur.com/7kXQF8Z.png">
<img class="kitty k2" src="https://i.imgur.com/7kXQF8Z.png">
<img class="kitty k3" src="https://i.imgur.com/7kXQF8Z.png">
<img class="kitty k4" src="https://i.imgur.com/7kXQF8Z.png">

<script>
setTimeout(() => {
  document.getElementById("welcome").style.display = "none";
}, 3000);
</script>

<!-- 💙 HEARTS -->
<script>
function createHeart() {
  const heart = document.createElement("div");
  heart.classList.add("heart");
  heart.innerText = "💙";

  heart.style.left = Math.random() * 100 + "vw";
  heart.style.animationDuration = (3 + Math.random() * 5) + "s";

  document.body.appendChild(heart);
  setTimeout(() => heart.remove(), 8000);
}
setInterval(createHeart, 250);
</script>

<header>
💙 Martinez’s Flower Designs 💙
</header>

<section>
<p>Blue Hello Kitty flower shop 🎀</p>
<button onclick="openTikTok()">TikTok @martinezs.flowers</button>
</section>

<!-- SHOP -->
<section>
<h2>Shop 💐</h2>

<div class="card">🌷 Tulips $10 <button onclick="addItem('Tulips',10)">Add</button></div>
<div class="card">🌼 Daisies $9 <button onclick="addItem('Daisies',9)">Add</button></div>
<div class="card">🌺 Hibiscus $12 <button onclick="addItem('Hibiscus',12)">Add</button></div>
<div class="card">🐯 Tiger Lilies $13 <button onclick="addItem('Tiger Lilies',13)">Add</button></div>
<div class="card">🤍 Lilies $12 <button onclick="addItem('Lilies',12)">Add</button></div>
</section>

<!-- CART -->
<section>
<h2>Cart 🛒</h2>

<div class="card">
<p id="cart">Empty</p>
<p id="total">Total: $0</p>

<button onclick="sendSMS()">Send Order 📲</button>
<button onclick="copyTT()">Copy TikTok 💙</button>
<button onclick="sendTT()">Send on TikTok 🎀</button>
<button onclick="showThanks()">Finish Order 💌</button>
</div>
</section>

<!-- THANK YOU -->
<div id="thankyou">
<h2>💙 Thank You!</h2>
<p>Your order was received 🎀</p>
</div>

<script>

let cart = [];
let total = 0;

/* CART */
function addItem(name, price) {
  cart.push(name);
  total += price;
  update();
}

function update() {
  document.getElementById("cart").innerText = cart.join(", ") || "Empty";
  document.getElementById("total").innerText = "Total: $" + total;
}

/* MUSIC */
function toggleMusic() {
  let music = document.getElementById("music");
  if (music.paused) music.play();
  else music.pause();
}

/* SMS */
function sendSMS() {
  let msg =
`NEW ORDER 💙
Items: ${cart.join(", ")}
Total: $${total}
Zelle: 201-736-5461`;

  window.open("sms:2017365461&body=" + encodeURIComponent(msg));
}

/* TIKTOK */
function copyTT() {
  navigator.clipboard.writeText(
`ORDER 💙
Items: ${cart.join(", ")}
Total: $${total}`
  );
  alert("Copied 💙");
}

function sendTT() {
  navigator.clipboard.writeText(
`Hey @martinezs.flowers 💙
Order: ${cart.join(", ")}
Total: $${total}`
  );
  window.open("https://www.tiktok.com/@martinezs.flowers");
}

/* THANK YOU */
function showThanks() {
  document.getElementById("thankyou").style.display = "block";
  setTimeout(() => {
    document.getElementById("thankyou").style.display = "none";
  }, 3000);
}

/* TIKTOK LINK */
function openTikTok() {
  window.open("https://www.tiktok.com/@martinezs.flowers");
}

</script>

</body>
</html>
